<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sovereign Dashboard - 10% Admin"
        Height="870"
        Width="1100"
        Background="#1E1E1E"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
        <Window.Resources>
                <!-- Base Button Style -->
                <Style TargetType="{x:Type Button}">
                        <Setter Property="Background"
                                Value="#2D2D2D"/>
                        <Setter Property="Foreground"
                                Value="#F1F1F1"/>
                        <Setter Property="BorderBrush"
                                Value="#3F3F46"/>
                        <Setter Property="Padding"
                                Value="8"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="3">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                </Border>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="#3F3F46"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- Accent Button Style (for Build) -->
                <Style x:Key="AccentButton"
                       TargetType="{x:Type Button}"
                       BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background"
                                Value="#007ACC"/>
                        <Setter Property="Foreground"
                                Value="#FFFFFF"/>
                        <Setter Property="BorderBrush"
                                Value="#007ACC"/>
                        <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                        <Setter Property="Background"
                                                Value="#0097FF"/>
                                        <Setter Property="BorderBrush"
                                                Value="#0097FF"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>

                <!-- TextBox Style -->
                <Style TargetType="{x:Type TextBox}">
                        <Setter Property="Background"
                                Value="#2D2D2D"/>
                        <Setter Property="Foreground"
                                Value="#F1F1F1"/>
                        <Setter Property="BorderBrush"
                                Value="#3F3F46"/>
                        <Setter Property="BorderThickness"
                                Value="1"/>
                        <Setter Property="Padding"
                                Value="4"/>
                        <Setter Property="VerticalContentAlignment"
                                Value="Center"/>
                        <Setter Property="CaretBrush"
                                Value="#F1F1F1"/>
                </Style>

                <!-- CheckBox Style for List Items -->
                <Style TargetType="{x:Type CheckBox}">
                        <Setter Property="Foreground"
                                Value="#F1F1F1"/>
                        <Setter Property="Margin"
                                Value="5,5,0,5"/>
                        <Setter Property="FontSize"
                                Value="14"/>
                        <Style.Triggers>
                                <Trigger Property="IsEnabled"
                                         Value="False">
                                        <Setter Property="Foreground"
                                                Value="#7A7A7A"/>
                                </Trigger>
                        </Style.Triggers>
                </Style>
        </Window.Resources>

        <!-- Main Application Grid -->
        <Grid Margin="15">
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0"
                            Margin="0,0,0,15">
                        <TextBlock Text="Sovereign Dashboard"
                                   Foreground="#F1F1F1"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="Image Architecture &amp; Subtraction Tool"
                                   Foreground="#007ACC"
                                   FontSize="14"/>
                </StackPanel>

                <!-- Toolbar / Search -->
                <Grid Grid.Row="1"
                      Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Name="SearchBox"
                                 Grid.Column="0"
                                 VerticalAlignment="Center"
                                 Height="30"
                                 Margin="0,0,15,0"/>
                        <TextBlock Text="Search Components..."
                                   Grid.Column="0"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Foreground="Gray"
                                   Margin="8,0,15,0">
                                <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility"
                                                        Value="Hidden"/>
                                                <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=SearchBox, Path=Text.Length}"
                                                                     Value="0">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible"/>
                                                        </DataTrigger>
                                                </Style.Triggers>
                                        </Style>
                                </TextBlock.Style>
                        </TextBlock>

                        <Button Name="BtnSelectAll"
                                Grid.Column="1"
                                Content="Check All"
                                Width="100"
                                Margin="0,0,10,0"
                                Height="30"/>
                        <Button Name="BtnPhysicalist"
                                Grid.Column="2"
                                Content="Physicalist Preset"
                                Width="130"
                                Height="30"/>
                </Grid>

                <!-- Main Component List (Scrollable Checkboxes) -->
                <Border Grid.Row="2"
                        Background="#2D2D2D"
                        BorderBrush="#3F3F46"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Margin="10">
                                <!-- This ItemsControl will be dynamically populated by PowerShell -->
                                <ItemsControl Name="ComponentList">
                                        <ItemsControl.GroupStyle>
                                                <GroupStyle>
                                                        <GroupStyle.ContainerStyle>
                                                                <Style TargetType="{x:Type GroupItem}">
                                                                        <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                                                                                <Expander IsExpanded="True"
                                                                                                          Foreground="#F1F1F1"
                                                                                                          Margin="0,0,0,15">
                                                                                                        <Expander.Header>
                                                                                                                <TextBlock Text="{Binding Name}"
                                                                                                                           FontWeight="Bold"
                                                                                                                           FontSize="16"
                                                                                                                           Foreground="#007ACC"
                                                                                                                           Margin="0,5,0,5"/>
                                                                                                        </Expander.Header>
                                                                                                        <ItemsPresenter Margin="20,0,0,0"/>
                                                                                                </Expander>
                                                                                        </ControlTemplate>
                                                                                </Setter.Value>
                                                                        </Setter>
                                                                </Style>
                                                        </GroupStyle.ContainerStyle>
                                                </GroupStyle>
                                        </ItemsControl.GroupStyle>
                                        <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                        <CheckBox IsChecked="{Binding Action}">
                                                                <StackPanel Margin="5,-2,0,8">
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="#F1F1F1"/>
                                                                        <TextBlock Text="{Binding Description}"
                                                                                   FontSize="12"
                                                                                   Foreground="#AAAAAA"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                        </CheckBox>
                                                </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                </ItemsControl>
                        </ScrollViewer>
                </Border>

                <!-- Configuration -->
                <Grid Grid.Row="3"
                      Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="ISO Path:"
                                   Foreground="#F1F1F1"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox Name="TxtWimPath"
                                 Grid.Column="1"
                                 AllowDrop="True"
                                 VerticalAlignment="Center"
                                 Height="25"
                                 Margin="0,0,5,0"/>

                        <Button Name="BtnBrowseWim"
                                Grid.Column="2"
                                Content="..."
                                Width="30"
                                Height="25"
                                Margin="0,0,15,0"/>

                        <TextBlock Text="Admin User:"
                                   Grid.Column="3"
                                   Foreground="#F1F1F1"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox Name="TxtUsername"
                                 Grid.Column="4"
                                 Text="SovereignAdmin"
                                 VerticalAlignment="Center"
                                 Height="25"
                                 Margin="0,0,15,0"/>

                        <TextBlock Text="Password:"
                                   Grid.Column="5"
                                   Foreground="#F1F1F1"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox Name="TxtPassword"
                                 Grid.Column="6"
                                 Text="Password123"
                                 VerticalAlignment="Center"
                                 Height="25"/>

                        <TextBlock Grid.Row="1"
                                   Text="Edition Index:"
                                   Foreground="#F1F1F1"
                                   VerticalAlignment="Center"
                                   Margin="0,10,10,0"/>
                        <Grid Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,10,5,0">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Name="CmbWimIndex"
                                          Grid.Column="0"
                                          VerticalAlignment="Center"
                                          Height="25"/>
                                <Button Name="BtnScanWim"
                                        Grid.Column="1"
                                        Content="Scan Editions"
                                        Width="100"
                                        Height="25"
                                        Margin="5,0,0,0"/>
                        </Grid>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   FontSize="12">
                                <Hyperlink Name="LnkDownloadIso"
                                           Foreground="#007ACC"
                                           TextDecorations="Underline">
                                        Don't have an image? Download the official Windows 11 ISO here.
                                </Hyperlink>
                        </TextBlock>

                        <CheckBox Name="ChkBuiltInAdmin"
                                  Grid.Row="2"
                                  Grid.Column="3"
                                  Grid.ColumnSpan="4"
                                  Content="Use Built-in Administrator Account"
                                  Margin="0,10,0,0"/>
                </Grid>

                <!-- Tools Area -->
                <Grid Grid.Row="4"
                      Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Integration Tools:"
                                   Foreground="#007ACC"
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"/>
                        <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Column 1: Core OS Bloat & Policies -->
                                <StackPanel Grid.Column="0"
                                            Orientation="Vertical"
                                            Margin="0,0,10,0">
                                        <CheckBox Name="ChkToolRegionPolicy"
                                                  IsChecked="True"
                                                  Margin="5,0,0,5">
                                                <TextBlock TextWrapping="Wrap">
                                                        <Run Text="Global Kill Policy (IntegratedServicesRegionPolicySet.json)"/>
                                                        <LineBreak/>
                                                        <Run Text="[Warning: Updates may overwrite]"
                                                             Foreground="#D4A017"
                                                             FontSize="12"
                                                             FontStyle="Italic"/>
                                                </TextBlock>
                                        </CheckBox>
                                        <CheckBox Name="ChkToolKillCopilot"
                                                  Content="Windows CoPilot (Removed)"
                                                  IsChecked="True"
                                                  Margin="25,5,0,0"/>
                                        <CheckBox Name="ChkToolKillRecall"
                                                  Content="Manage Recall (Removed)"
                                                  IsChecked="True"
                                                  Margin="25,5,0,0"/>
                                        <CheckBox Name="ChkToolKillEdge"
                                                  Content="Edge (Removed)"
                                                  IsChecked="True"
                                                  Margin="25,5,0,0"/>
                                        <CheckBox Name="ChkToolWebSearch"
                                                  Content="User can disable web search (Enabled)"
                                                  IsChecked="True"
                                                  Margin="25,5,0,0"/>
                                        <CheckBox Name="ChkToolCampaigns"
                                                  Content="Campaign segment targeting (Removed)"
                                                  IsChecked="True"
                                                  Margin="25,5,0,0"/>
                                        <CheckBox Name="ChkToolPromos"
                                                  Content="Full screen promotional surface (Removed)"
                                                  IsChecked="True"
                                                  Margin="25,5,0,0"/>
                                        <CheckBox Name="ChkToolKillOneDrive"
                                                  Content="OneDrive (Removed)"
                                                  IsChecked="True"
                                                  Margin="25,5,0,0"/>
                                        <CheckBox Name="ChkToolKillDefender"
                                                  Content="Windows Defender (Removed)"
                                                  IsChecked="False"
                                                  Margin="25,5,0,10"/>
                                        <TextBlock Text="Appx Bloatware Removal:"
                                                   Foreground="#AAAAAA"
                                                   Margin="25,0,0,5"/>
                                        <StackPanel Orientation="Vertical"
                                                    Margin="35,0,0,5">
                                                <RadioButton Name="OptNukeNone"
                                                             Content="Keep All"
                                                             IsChecked="True"
                                                             Foreground="#F1F1F1"
                                                             Margin="0,0,0,5"/>
                                                <RadioButton Name="OptNukeWhitelisted"
                                                             Content="Nuke Bloatware (Keep Whitelisted Items)"
                                                             Foreground="#F1F1F1"
                                                             Margin="0,0,0,5"/>
                                                <RadioButton Name="OptNukeAll"
                                                             Content="Full Nuke"
                                                             Foreground="#E74C3C"
                                                             Margin="0,0,0,5"/>
                                        </StackPanel>
                                </StackPanel>

                                <!-- Column 2: System Tweaks & Upgrades -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Vertical"
                                            Margin="10,0,0,0">
                                        <CheckBox Name="ChkToolDisableUCPD"
                                                  Content="Disable User Choice Protection Driver (UCPD)"
                                                  IsChecked="True"
                                                  Margin="5,0,0,5"/>
                                        <CheckBox Name="ChkToolQoLTweaks"
                                                  Content="Apply QoL Tweaks &amp; Add WinUtil Launcher (Classic Menu, File Extensions, etc.)"
                                                  IsChecked="True"
                                                  Margin="5,0,0,5"/>
                                        <CheckBox Name="ChkToolDisableIndexing"
                                                  Content="Disable Windows Search Indexing Service (WSearch)"
                                                  IsChecked="True"
                                                  Margin="5,0,0,5"/>
                                        <CheckBox Name="ChkToolBypassTPM"
                                                  Content="Bypass Windows 11 Hardware Checks (TPM, CPU, Secure Boot)"
                                                  IsChecked="True"
                                                  Margin="5,0,0,5"/>
                                        <CheckBox Name="ChkToolCustomInstaller"
                                                  Content="Use Custom Sovereign Installer (Bypass Microsoft Setup)"
                                                  Foreground="#007ACC"
                                                  FontWeight="SemiBold"
                                                  Margin="5,0,0,5"/>
                                        <CheckBox Name="ChkToolInstallOpenShell"
                                                  Content="Install Open-Shell (Classic Start Menu)"
                                                  IsChecked="False"
                                                  Margin="5,0,0,10"/>
                                        <TextBlock Text="Windows Update Behavior:"
                                                   Foreground="#AAAAAA"
                                                   Margin="5,10,0,5"/>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="5,0,0,5">
                                                <RadioButton Name="OptWuDefault"
                                                             Content="Default (Enabled)"
                                                             IsChecked="True"
                                                             Foreground="#F1F1F1"
                                                             Margin="0,0,15,0"/>
                                                <RadioButton Name="OptWuSecurity"
                                                             Content="Security Updates Only"
                                                             Foreground="#F1F1F1"
                                                             Margin="0,0,15,0"/>
                                                <RadioButton Name="OptWuDisable"
                                                             Content="Completely Disabled"
                                                             Foreground="#F1F1F1"/>
                                        </StackPanel>
                                </StackPanel>
                        </Grid>
                </Grid>

                <!-- Footer Actions -->
                <Grid Grid.Row="5"
                      Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Name="BtnMount"
                                Grid.Column="1"
                                Content="Mount ISO..."
                                Width="120"
                                Height="35"
                                Margin="0,0,15,0"/>
                        <Button Name="BtnBuild"
                                Grid.Column="2"
                                Content="Build ISO"
                                Style="{StaticResource AccentButton}"
                                Width="150"
                                Height="35"/>
                </Grid>
        </Grid>
</Window>
